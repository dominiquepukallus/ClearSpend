<div class="bg-white dark:bg-gray-900 flex flex-col">

  <%# Hero section %>
  <div class="relative isolate flex items-center justify-center pt-32 pb-20 px-6 lg:px-8">
    <div aria-hidden="true" class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80">
      <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="relative left-[calc(50%-11rem)] aspect-1155/678 w-144.5 -translate-x-1/2 rotate-30 bg-linear-to-tr from-[#ff80b5] to-[#9089fc] opacity-30 sm:left-[calc(50%-30rem)] sm:w-288.75"></div>
    </div>

    <div class="text-center">
      <h1 class="text-5xl font-semibold tracking-tight text-gray-900 sm:text-7xl">Clear Spend</h1>
      <p class="mt-8 text-lg font-medium text-gray-500 sm:text-xl">Do you really know how much you're spending on subscriptions?<br>This app helps you track and understand all of your subscriptions</p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <%= link_to "Create an account", new_user_registration_path, class: "rounded-md bg-indigo-400 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 min-w-36 text-center" %>
        <%= link_to "Login", new_user_session_path, class: "rounded-md bg-emerald-400 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-emerald-600 min-w-36 text-center" %>
      </div>
    </div>

  </div>

  <%# Features section %>
      <div id="features" class="bg-white py-24 sm:py-32 dark:bg-gray-900">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 space-y-32">

          <div class="flex items-center gap-16">
            <div class="w-1/5 shrink-0">
              <h3 class="text-3xl font-semibold text-gray-900">Calendar</h3>
              <p class="mt-4 text-lg text-gray-600">You can easily check which subscriptions will be charged and on what date.</p>
            </div>
            <div class="flex-1">
              <%= image_tag "full_calender.png", alt: "Calendar", class: "w-[150%] max-w-5xl rounded-2xl shadow-xl" %>
            </div>
          </div>

          <div class="flex items-center gap-16">
            <div class="w-2/3 shrink-0">
              <%= image_tag "full_dashboard.png", alt: "Dashboard", class: "w-full rounded-2xl shadow-xl" %>
            </div>
            <div class="w-1/3 shrink-0">
              <h3 class="text-3xl font-semibold text-gray-900">Dashboard</h3>
              <p class="mt-4 text-lg text-gray-600">You can track your monthly spending and view a detailed breakdown of your expenses by category.</p>
            </div>
          </div>

          <div class="flex items-center gap-16">
            <div class="w-1/5 shrink-0">
              <h3 class="text-3xl font-semibold text-gray-900">AI Insight</h3>
              <p class="mt-4 text-lg text-gray-600">AI analyzes your spending patterns and provides personalized suggestions on which subscriptions you could cancel to optimize your expenses.</p>
            </div>
            <div class="flex-1">
              <%= image_tag "full_ai_insight.png", alt: "AI Insights", class: "w-[150%] max-w-5xl rounded-2xl shadow-xl" %>
            </div>
          </div>

        </div>
      </div>
</div>
