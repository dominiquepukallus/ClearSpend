<div class="bg-white dark:bg-gray-900 flex flex-col">

  <%# Hero section %>
  <div class="relative isolate flex items-center justify-center pt-32 pb-20 px-6 lg:px-8">
    <div aria-hidden="true" class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80">
      <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="relative left-[calc(50%-11rem)] aspect-1155/678 w-144.5 -translate-x-1/2 rotate-30 bg-linear-to-tr from-[#ff80b5] to-[#9089fc] opacity-30 sm:left-[calc(50%-30rem)] sm:w-288.75"></div>
    </div>

      <div class="text-center max-w-3xl mx-auto">
      <%= image_tag "logo_white.svg", class: "w-96 h-auto mx-auto mb-8", style: "margin-left: 9rem;" %>

      <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl mb-4">
        Take control of your subscriptions
      </h1>

      <p class="text-lg text-gray-600 sm:text-xl mb-10">
        Track every subscription. Cancel what you don't need. Save money.
      </p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <%= link_to "Create an account", new_user_registration_path, class: "rounded-md bg-[#1B2B4B] px-5 py-3 text-sm font-semibold text-white shadow-xs hover:bg-[#85B7EB] min-w-36 text-center" %>
        <%= link_to new_user_session_path, class: "rounded-md bg-[#85B7EB] px-5 py-3 text-sm font-semibold text-white shadow-xs hover:bg-[#1B2B4B] min-w-36 text-center inline-flex items-center justify-center gap-2" do %>
          <span>Login</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m12.75 15 3-3m0 0-3-3m3 3h-7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        <% end %>
      </div>
    </div>

  </div>

  <%# Features section %>
      <div id="features" class="bg-white py-24 sm:py-32 dark:bg-gray-900">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 space-y-32">

          <div class="flex items-center gap-16">
            <div class="w-1/5 shrink-0">
              <h3 class="text-3xl font-semibold text-gray-900">Stay Organized</h3>
              <p class="mt-4 text-lg text-gray-600">Easily check which subscriptions will be charged and on what date with our intuitive calendar view.</p>
            </div>
            <div class="flex-1">
              <%= image_tag "calendar-final.png", alt: "Calendar", class: "w-[150%] max-w-5xl rounded-2xl shadow-xl" %>
            </div>
          </div>

          <div class="flex items-center gap-16">
            <div class="w-2/3 shrink-0">
              <%= image_tag "dashboard-final.png", alt: "Dashboard", class: "w-full rounded-2xl shadow-xl" %>
            </div>
            <div class="w-1/3 shrink-0">
              <h3 class="text-3xl font-semibold text-gray-900">Detailed Analytics</h3>
              <p class="mt-4 text-lg text-gray-600">View a detailed breakdown of your expenses with visual charts and spending insights</p>
            </div>
          </div>

          <div class="flex items-center gap-16">
            <div class="w-1/5 shrink-0">
              <h3 class="text-3xl font-semibold text-gray-900">Smart savings recommendations</h3>
              <p class="mt-4 text-lg text-gray-600">AI analyzes your spending patterns and provides personalized suggestions to help you optimize expenses and save more.</p>
            </div>
            <div class="flex-1">
              <%= image_tag "insights-final.png", alt: "AI Insights", class: "w-[150%] max-w-5xl rounded-2xl shadow-xl" %>
            </div>
          </div>

        </div>
      </div>
</div>
