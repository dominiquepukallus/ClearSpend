<div class="flex flex-col items-center pt-1 px-10 w-full pb-40">
  <div class="flex flex-col items-center">
    <%= image_tag "ClearSpend.svg", class: "w-[1000px] mr-40" %>
    <div class="flex items-center gap-10 [&>a]:w-64 [&>a]:text-center">
      <%= link_to "Current subscriptions", subscriptions_path, class: "bg-[#1B2B4B] text-white font-semibold px-4 py-4 rounded-xl shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 hover:bg-[#B5D4F4] hover:shadow-[0_4px_20px_#B5D4F4] transition-all no-underline", style: "text-decoration: none;" %>
      <%= link_to "Analytics", dashboard_path, class: "bg-[#85B7EB] text-white font-semibold px-4 py-4 rounded-xl shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 hover:bg-[#B5D4F4] hover:shadow-[0_4px_20px_#B5D4F4] transition-all no-underline", style: "text-decoration: none;" %>
      <%= link_to "Add a subscription", new_subscription_path, class: "bg-[#85B7EB] text-white font-semibold px-4 py-4 rounded-xl shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 hover:bg-[#B5D4F4] hover:shadow-[0_4px_20px_#B5D4F4] transition-all no-underline", style: "text-decoration: none;" %>
    </div>
  </div>
</div>
