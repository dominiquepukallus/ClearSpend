<div class="flex flex-col items-start pt-1 px-10 w-full">
  <%= image_tag "ClearSpend.svg", class: "w-[800px] max-w-full h-auto object-contain", id: "logo-light" %>
  <%= image_tag "logo_revert.svg", class: "w-[800px] max-w-full h-auto object-contain hidden", id: "logo-dark" %>
</div>

<main class="min-h-screen px-8 pb-8"
  data-controller="dashboard-activity-modal"
  data-action="keydown.esc@window->dashboard-activity-modal#closeWithKeyboard"
  data-dashboard-scroll-target="main">

  <%= turbo_frame_tag "dashboard-main", data: { turbo_action: "replace" } do %>
    <div class="w-full max-w-[1060px] mx-auto">

      <!-- Header -->
      <header class="flex items-center justify-between gap-6 w-full mb-6">
        <p id="greeting" class="text-lg text-[#6c7285]">
          <strong class="font-bold">Hi, <%= current_user.first_name.presence || current_user.alias %></strong>. Have a look at your <strong class="font-bold">monthly</strong> analytics
        </p>

        <!-- Filter by month -->
        <div class="relative" data-controller="custom-select">
          <%= form_with url: dashboard_path, method: :get, data: { turbo_frame: "dashboard-main" } do |f| %>
            <% month_labels = (Date.new(2025,1)..Date.current).map { |d| [d.strftime("%B %Y"), d.strftime("%Y-%m")] }.uniq %>

            <button type="button"
              data-custom-select-target="button"
              data-action="click->custom-select#toggle dblclick->custom-select#resetToToday"
              class="flex items-center gap-2 rounded-lg bg-white px-4 py-3 text-sm font-medium shadow-lg whitespace-nowrap w-fit">
              <i class="fa-solid fa-calendar text-[#229be8]"></i>
              <span class="text-[#1f2328] text-sm font-semibold"><%= @selected_month.strftime("%B %Y") %></span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-gray-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>

            <div data-custom-select-target="menu" class="hidden absolute top-full left-0 mt-1 bg-white rounded-md shadow-lg outline outline-1 outline-gray-200 z-50 min-w-full" style="max-height: 280px; overflow-y: scroll;">
              <% month_labels.reverse.each do |label, value| %>
                <button type="submit"
                    name="month"
                    value="<%= value %>"
                    class="block w-full text-left my-2 px-4 text-sm text-gray-700 hover:bg-gray-100 whitespace-nowrap <%= @selected_month.strftime("%Y-%m") == value ? 'font-semibold text-[#1B2B4B]' : '' %>">
                  <%= label %>
                </button>
              <% end %>
            </div>
          <% end %>
        </div>
      </header>

      <!-- Grid -->
      <div class="grid grid-cols-[1fr_340px] gap-6 items-start">
        <div class="grid gap-4">
          <%= render "dashboard/stats" %>
          <%= render "dashboard/breakdown" %>
          <%= render "dashboard/analytics" %>
        </div>
        <aside>
          <%= render "ai_insights_card", insights: @insights, return_to: request.fullpath %>
        </aside>
      </div>

    </div>
    <%= render "dashboard/modal" %>
  <% end %>

</main>
