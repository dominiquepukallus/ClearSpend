<% category_colors = {
  "Entertainment" => "#7C3AED",
  "Well-being" => "#4CAF7D",
  "News & Information" => "#1E3A5F",
  "Food & Delivery / Meal kits" => "#F97316",
  "Software & Productivity" => "#2563EB",
  "Shopping & Retail" => "#EC4899",
  "Customized" => "#4B5563"
} %>
<% fallback_colors = ["#5b7cf6", "#7be3a6", "#ffc45c", "#ff7888", "#9b8cff", "#4fd1c5"] %>
<% breakdown_rows = @subscription_breakdown.sort_by { |category, _amount| category_colors.keys.index(category) || category_colors.length } %>
<% breakdown_labels = breakdown_rows.map(&:first) %>
<% breakdown_values = breakdown_rows.map { |_category, amount| amount.to_f } %>
<% breakdown_colors = breakdown_labels.each_with_index.map { |category, index| category_colors.fetch(category, fallback_colors[index % fallback_colors.length]) } %>

<main class="dashboard-page" data-controller="dashboard-activity-modal" data-action="keydown.esc@window->dashboard-activity-modal#closeWithKeyboard">
  <div class="dashboard-shell">
    <header class="dashboard-header">
      <div>
        <h1>Dashboard</h1>
        <p>Hi, <%= current_user.first_name.presence || current_user.alias %>. Welcome back to ClearSpend Admin!</p>
      </div>

      <%= form_with url: dashboard_path, method: :get, class: "dashboard-month-filter" do |form| %>
        <span class="dashboard-month-filter__icon">
          <i class="fa-regular fa-calendar"></i>
        </span>
        <label for="month">
          <strong>Filter month</strong>
          <small><%= @month_range.first.strftime("%d %B %Y") %> - <%= @month_range.last.strftime("%d %B %Y") %></small>
        </label>
        <%= form.month_field :month, value: @selected_month.strftime("%Y-%m"), class: "dashboard-month-filter__input" %>
        <%= form.submit "Apply", class: "dashboard-month-filter__submit" %>
      <% end %>
    </header>

    <div class="dashboard-grid">
      <div class="dashboard-main">
        <section class="dashboard-stats" aria-label="Subscription summary">
          <article class="dashboard-stat-card">
            <span>Monthly spend</span>
            <strong><%= number_to_currency(@monthly_spend, precision: 0) %></strong>
          </article>

          <article class="dashboard-stat-card dashboard-stat-card--cancelled">
            <span>Cancelled this month</span>
            <strong><%= number_to_currency(@canceled_subscriptions, precision: 0) %></strong>
          </article>
        </section>

        <section class="subscriptions-breakdown-card">
          <div class="subscriptions-breakdown-card__header">
            <h1>Subscriptions breakdown</h1>
          </div>

          <div
            class="subscriptions-chart"
            data-controller="subscriptions-breakdown-chart"
            data-subscriptions-breakdown-chart-labels-value="<%= json_escape(breakdown_labels.to_json) %>"
            data-subscriptions-breakdown-chart-values-value="<%= json_escape(breakdown_values.to_json) %>"
            data-subscriptions-breakdown-chart-colors-value="<%= json_escape(breakdown_colors.to_json) %>"
            data-subscriptions-breakdown-chart-total-value="<%= @subscription_breakdown_total.to_f %>"
          >
            <canvas data-subscriptions-breakdown-chart-target="canvas" aria-label="Subscriptions breakdown by category"></canvas>
          </div>

          <div class="subscriptions-breakdown-legend">
            <% if @subscription_breakdown.any? %>
              <% breakdown_rows.each_with_index do |(category, amount), index| %>
                <div class="legend-item">
                  <span class="legend-dot" style="--legend-color: <%= breakdown_colors[index] %>"></span>
                  <span class="legend-label"><%= category %></span>
                  <strong><%= number_to_currency(amount, precision: 0) %></strong>
                </div>
              <% end %>
            <% else %>
              <div class="legend-item legend-item--empty">
                <span class="legend-dot"></span>
                <span class="legend-label">No subscriptions yet</span>
                <strong><%= number_to_currency(0, precision: 0) %></strong>
              </div>
            <% end %>
          </div>
        </section>
      </div>

      <aside class="dashboard-side">
        <% if @insights.any? %>
          <% insight = @insights.last %>
          <%= link_to insights_path(category_id: insight.category_id), class: "dashboard-ai-card" do %>
            <div class="dashboard-ai-card__header">
              <h2 class="mb-6">AI Insight</h2>
              <span class="insight-badge text-sm"><%= insight.category.name %></span>
            </div>
            <div class="dashboard-ai-card__content">
              <div class="insight-subscription ">
                <span class="sub-name"><%= insight.subscription.name %></span>
                <span class="sub-amount">$<%= insight.subscription.amount %></span>
              </div>
              <p class="insight-text text-sm mt-3 mb-3"><%= insight.insight_text %></p>
              <span class="view-more ">View all insights →</span>
            </div>
          <% end %>
        <% else %>
          <section class="dashboard-ai-card">
            <div class="dashboard-ai-card__header">
              <h2>AI Insights</h2>
            </div>
            <div class="dashboard-ai-card__content">
              <p>No insights yet.</p>
            </div>
          </section>
        <% end %>


        <section class="dashboard-analytics-card">
          <div class="dashboard-analytics-card__header">
            <h2>Analytics</h2>
            <button type="button" data-action="dashboard-activity-modal#open">View Analytics</button>
          </div>
          <p>
            <%= @added_subscriptions.count %> added
            <span><%= @canceled_subscription_details.count %> cancelled</span>
          </p>
          <svg viewBox="0 0 280 72" role="img" aria-label="Monthly subscription activity trend">
            <polyline points="0,50 54,36 108,44 162,64 216,40 280,38" />
          </svg>
        </section>
      </aside>
    </div>
  </div>

  <div
    id="monthly-activity-modal"
    class="dashboard-modal"
    aria-hidden="true"
    aria-labelledby="monthly-activity-title"
    role="dialog"
    data-dashboard-activity-modal-target="modal"
  >
    <button type="button" class="dashboard-modal__backdrop" aria-label="Close monthly activity" data-action="dashboard-activity-modal#close"></button>
    <section class="dashboard-modal__panel">
      <header class="dashboard-modal__header">
        <div>
          <h2 id="monthly-activity-title">Monthly activity</h2>
          <p><%= @selected_month.strftime("%B %Y") %></p>
        </div>
        <button type="button" aria-label="Close monthly activity" data-action="dashboard-activity-modal#close">Close</button>
      </header>

      <div class="dashboard-activity-grid">
        <section>
          <h3>Added subscriptions</h3>
          <% if @added_subscriptions.any? %>
            <div class="dashboard-activity-list">
              <% @added_subscriptions.each do |subscription| %>
                <article class="dashboard-activity-item">
                  <div>
                    <strong><%= subscription.name %></strong>
                    <span><%= subscription.date_recurrence.strftime("%d %b") %> · <%= subscription.category.name %> · <%= subscription.billing_cycle.titleize %></span>
                  </div>
                  <span><%= number_to_currency(subscription.amount, precision: 0) %></span>
                </article>
              <% end %>
            </div>
          <% else %>
            <p class="dashboard-activity-empty">No subscriptions added this month.</p>
          <% end %>
        </section>

        <section>
          <h3>Cancelled subscriptions</h3>
          <% if @canceled_subscription_details.any? %>
            <div class="dashboard-activity-list">
              <% @canceled_subscription_details.each do |subscription| %>
                <article class="dashboard-activity-item">
                  <div>
                    <strong><%= subscription.name %></strong>
                    <span>Cancelled <%= subscription.cancelled_at.strftime("%d %b") %> · <%= subscription.category.name %></span>
                  </div>
                  <span><%= number_to_currency(subscription.amount, precision: 0) %></span>
                </article>
              <% end %>
            </div>
          <% else %>
            <p class="dashboard-activity-empty">No subscriptions cancelled this month.</p>
          <% end %>
        </section>
      </div>
    </section>
  </div>
</main>
