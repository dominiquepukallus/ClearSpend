<% category_hex = Category.all.each_with_object({}) { |c, h| h[c.name] = c.hex_color } %>
<% chart_rows = @subscription_breakdown.sort_by { |name, _| Category::SEEDED_NAMES.index(name) || Category::SEEDED_NAMES.length } %>
<% breakdown_labels = chart_rows.map(&:first) %>
<% breakdown_values = chart_rows.map { |_, amount| amount.to_f } %>
<% breakdown_colors = breakdown_labels.map { |name| category_hex[name] || "#9CA3AF" } %>

<% sorted = @subscription_breakdown.sort_by { |_, amount| -amount }.map { |name, amount| [name, amount, category_hex[name] || "#9CA3AF"] } %>
<% half = (sorted.size / 2.0).ceil %>
<% left_col = sorted[0...half] %>
<% right_col = sorted[half..] || [] %>
<% interleaved = left_col.zip(right_col).flatten(1).compact %>

<section class="bg-white rounded-lg shadow-[4px_2px_16px_#B5D4F4] px-6 pb-6 pt-4 overflow-visible">
  <h1 class="m-0 text-[#1B2B4B] text-xl font-bold mb-2">Breakdown</h1>
  <div class="w-60 h-[206px] mx-auto mt-2 mb-12"
    data-controller="subscriptions-breakdown-chart"
    data-subscriptions-breakdown-chart-labels-value="<%= json_escape(breakdown_labels.to_json) %>"
    data-subscriptions-breakdown-chart-values-value="<%= json_escape(breakdown_values.to_json) %>"
    data-subscriptions-breakdown-chart-colors-value="<%= json_escape(breakdown_colors.to_json) %>"
    data-subscriptions-breakdown-chart-total-value="<%= @subscription_breakdown_total.to_f %>"
  >
    <canvas data-subscriptions-breakdown-chart-target="canvas"></canvas>
  </div>
  <div class="grid grid-cols-2 gap-x-6 gap-y-2 mt-4">
    <% if @subscription_breakdown.any? %>
      <% interleaved.each do |(category_name, amount, color)| %>
        <div class="flex items-center justify-between gap-2 min-w-0 py-1.5 border-b border-gray-100 last:border-0">
          <div class="flex items-center gap-2 min-w-0">
            <span class="inline-block rounded-full flex-shrink-0" style="background-color: <%= color %>; width: 10px; height: 10px;"></span>
            <span class="text-xs text-gray-600 truncate"><%= category_name %></span>
          </div>
          <strong class="text-xs font-semibold text-[#1B2B4B] whitespace-nowrap"><%= number_to_currency(amount, precision: 0) %></strong>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-2 flex items-center gap-2 text-xs text-[#222833]">
        <span class="w-2 h-2 rounded-full border-2 border-[#cfd6e3]"></span>
        <span>No subscriptions yet</span>
      </div>
    <% end %>
  </div>
</section>
