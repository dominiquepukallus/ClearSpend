<div id="monthly-activity-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center"
    data-dashboard-activity-modal-target="modal"
>
  <div class="fixed inset-0 bg-black/50 cursor-pointer" data-action="click->dashboard-activity-modal#close"></div>
  <div class="relative z-10 w-full max-w-[760px] max-h-[82vh] p-6 overflow-y-auto bg-white rounded-lg shadow-2xl">
    <div class="flex items-start justify-between gap-4 mb-2">
      <h2 class="m-0 text-[#1B2B4B] text-xl font-extrabold" data-dashboard-activity-modal-target="title">Monthly activity</h2>
      <button type="button" data-action="dashboard-activity-modal#close" class="text-gray-400 hover:text-[#1b2b4b] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="grid grid-cols-2 gap-4" data-dashboard-activity-modal-target="activityGrid">
      <div data-dashboard-activity-modal-target="addedSection">
        <% if @added_subscriptions.any? %>
          <div class="grid gap-2.5">
            <% @added_subscriptions.each do |subscription| %>
              <article class="flex items-center justify-between gap-3 min-w-0 p-3 border border-[#eceff4] rounded-lg bg-[#fafbfc]">
                <div class="grid min-w-0">
                  <strong class="text-[#1f2328] text-[13px] font-extrabold truncate"><%= subscription.name %></strong>
                  <span class="text-[#7d83a6] text-[11px] truncate"><%= subscription.date_recurrence.strftime("%d %b") %> · <%= subscription.category.name %> · <%= subscription.billing_cycle.titleize %></span>
                </div>
                <span class="text-[#1f2328] font-extrabold whitespace-nowrap"><%= number_to_currency(subscription.amount, precision: 0) %></span>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="m-0 p-4 border border-dashed border-[#d8deea] rounded-lg text-[#7d83a6] bg-[#fafbfc] text-sm">No subscriptions added this month.</p>
        <% end %>
      </div>
      <div>
        <% if @canceled_subscription_details.any? %>
          <div class="grid gap-2.5">
            <% @canceled_subscription_details.each do |subscription| %>
              <article class="flex flex-col justify-between gap-3 min-w-0 p-3 border border-red-300 rounded-lg bg-rose-50 w-full min-h-[80px]">
                <div class="grid min-w-0">
                  <strong class="text-[#1B2B4B] text-sm truncate"><%= subscription.name %></strong>
                  <span class="text-[#1B2B4B] text-xs truncate">Cancelled <%= subscription.cancelled_at.strftime("%d %b") %> · <%= subscription.category.name %></span>
                </div>
                <span class="text-[#E24B4A] font-bold whitespace-nowrap text-right"><%= subscription_billing_amount_label(subscription) %></span>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="m-0 p-4 border border-dashed border-[#d8deea] rounded-lg text-[#7d83a6] bg-[#fafbfc] text-sm">No subscriptions cancelled this month.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
