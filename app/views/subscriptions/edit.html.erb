<div class="px-10 pt-6 pb-20 ml-15">

  <!-- Back link -->
  <%= link_to "← Back to subscription", subscription_path(@subscription), style: "text-decoration: none;", class: "text-sm text-gray-500 hover:text-[#1B2B4B]" %>

  <div class="mt-6 max-w-2xl">
    <div class="rounded-xl bg-white shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 overflow-hidden">

      <!-- Header -->
      <div class="<%= @subscription.category.color %> px-8 py-6">
        <h1 class="text-2xl font-bold text-white">Edit <%= @subscription.name %></h1>
        <p class="mt-1 text-sm text-white opacity-75">Update your subscription details</p>
      </div>

      <!-- Form -->
      <div class="px-8 py-6">
        <%= form_with model: @subscription, class: "flex flex-col gap-5" do |f| %>

          <div>
            <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Name</label>
            <%= f.text_field :name, class: "block w-full rounded-md border-0 bg-white py-3 px-4 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 placeholder:text-gray-500 focus:outline-2 focus:outline-[#1B2B4B]" %>
          </div>

          <div>
            <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Amount ($)</label>
            <%= f.number_field :amount, step: 0.01, class: "block w-full rounded-md border-0 bg-white py-3 px-4 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 placeholder:text-gray-500 focus:outline-2 focus:outline-[#1B2B4B]" %>
          </div>

          <div>
            <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Billing cycle</label>
            <%= f.select :billing_cycle, [["Monthly", "monthly"], ["Yearly", "yearly"], ["Weekly", "weekly"]], {}, class: "block w-full rounded-md border-0 bg-white py-3 px-4 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
          </div>

          <div>
            <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Start date</label>
            <%= f.date_field :date_recurrence, class: "block w-full rounded-md border-0 bg-white py-3 px-4 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
          </div>

          <div>
            <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Category</label>
            <%= f.collection_select :category_id, Category.all, :id, :name, {}, class: "block w-full rounded-md border-0 bg-white py-3 px-4 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
          </div>

          <div>
            <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Status</label>
            <%= f.select :status, [["Active", "active"], ["Cancelled", "cancelled"]], {}, class: "block w-full rounded-md border-0 bg-white py-3 px-4 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
          </div>

          <div class="flex gap-3 pt-2 border-t border-gray-100">
            <%= f.submit "Save changes", class: "bg-[#1B2B4B] text-white font-semibold px-6 py-3 rounded-xl shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 hover:bg-[#B5D4F4] transition-all cursor-pointer" %>
            <%= link_to "Cancel", subscription_path(@subscription), style: "text-decoration: none;", class: "bg-white text-gray-500 font-semibold px-6 py-3 rounded-xl shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 hover:bg-gray-50 transition-all" %>
          </div>

        <% end %>
      </div>

    </div>
  </div>
</div>
