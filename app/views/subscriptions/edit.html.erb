<%= turbo_frame_tag "modal_content" do %>
  <div class="px-6 py-6"> <!-- Reduced padding -->

    <div class="max-w-xl mx-auto"> <!-- Constrain width and center -->
      <div class="rounded-xl bg-white shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 overflow-hidden">

        <!-- Header -->
        <div class="<%= @subscription.category.color %> px-8 py-7">
          <h1 class="text-xl font-bold text-white p-3">Edit <%= @subscription.name %></h1>
          <%# <p class="mt-2 text-sm text-white opacity-75">Update your subscription details</p> %>
        </div>

        <!-- Form -->
        <div class="px-6 py-6">
          <%= form_with model: @subscription, class: "flex flex-col gap-4" do |f| %>

            <div>
              <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Name</label>
              <%= f.text_field :name, class: "block w-full rounded-md border-0 bg-white py-2.5 px-3 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 placeholder:text-gray-500 focus:outline-2 focus:outline-[#1B2B4B]" %>
            </div>

            <div>
              <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Amount ($)</label>
              <%= f.number_field :amount, step: 0.01, class: "block w-full rounded-md border-0 bg-white py-2.5 px-3 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 placeholder:text-gray-500 focus:outline-2 focus:outline-[#1B2B4B]" %>
            </div>

            <div>
              <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Billing cycle</label>
              <%= f.select :billing_cycle, [["Monthly", "monthly"], ["Yearly", "yearly"], ["Weekly", "weekly"]], {}, class: "block w-full rounded-md border-0 bg-white py-2.5 px-3 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
            </div>

            <div>
              <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Start date</label>
              <%= f.date_field :date_recurrence, class: "block w-full rounded-md border-0 bg-white py-2.5 px-3 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
            </div>

            <div>
              <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Category</label>
              <%= f.collection_select :category_id, Category.all, :id, :name, {}, class: "block w-full rounded-md border-0 bg-white py-2.5 px-3 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
            </div>

            <div>
              <label class="text-xs text-gray-400 uppercase tracking-wide mb-1 block">Status</label>
              <%= f.select :status, [["Active", "active"], ["Cancelled", "cancelled"]], {}, class: "block w-full rounded-md border-0 bg-white py-2.5 px-3 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
            </div>

            <div class="flex gap-3 pt-3 border-t border-gray-100">
              <%= f.submit "Save changes", class: "bg-[#1B2B4B] text-white font-semibold px-5 py-2.5 rounded-xl shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 hover:bg-[#B5D4F4] transition-all cursor-pointer text-sm" %>
             <button type="button"
                data-action="click->modal#close"
                class="bg-white text-gray-500 font-semibold px-5 py-2.5 rounded-xl shadow-[0_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 hover:bg-gray-50 transition-all text-sm">
                Cancel
            </button>
          <% end %>
        </div>

      </div>
    </div>
  </div>
<% end %>
