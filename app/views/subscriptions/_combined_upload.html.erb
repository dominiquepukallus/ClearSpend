<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

  <!-- Left Column: CSV Upload (top) + Bulk Upload (bottom) -->
  <div class="space-y-8">

    <!-- CSV Upload Section -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <h3 class="text-2xl font-bold mb-4 text-gray-800">📄 Upload CSV</h3>

      <%= form_with url: parse_csv_subscriptions_path,
          method: :post,
          multipart: true,
          data: { turbo_frame: "preview" } do |f| %>

        <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 mb-6 bg-gray-50 hover:bg-gray-100 transition-colors">
          <%= f.label :csv_file, class: "block mb-4 cursor-pointer" do %>
            <div class="text-4xl mb-2 text-center">📄</div>
            <div class="text-gray-700 font-semibold text-center">Choose CSV File</div>
            <div class="text-sm text-gray-500 mt-2 text-center">AI will categorize your subscriptions</div>
          <% end %>

          <%= f.file_field :csv_file,
              accept: ".csv",
              class: "block w-full mt-4" %>
        </div>

        <%= f.submit "Upload and Parse",
            class: "w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg cursor-pointer transition-colors" %>
      <% end %>
    </div>

    <!-- Bulk Upload Section -->
    <div class="bg-white rounded-lg shadow-md p-6" data-controller="bulk-subscriptions">
      <h3 class="text-2xl font-bold mb-4 text-gray-800">✏️ Bulk Entry</h3>
      <p class="text-gray-600 mb-6">Add multiple subscriptions at once</p>

      <%= form_with url: bulk_create_subscriptions_path, method: :post, data: { turbo_frame: "_top" } do |f| %>

        <div data-bulk-subscriptions-target="container" class="space-y-4">

          <!-- First subscription row -->
          <div data-bulk-subscription-row class="border border-gray-200 rounded-lg p-5 bg-gray-50">
            <div class="flex justify-between items-center mb-4">
              <h4 class="font-semibold text-gray-700 text-lg">Subscription #1</h4>
              <button type="button"
                      data-action="bulk-subscriptions#removeRow"
                      class="text-red-500 hover:text-red-700 font-medium text-sm transition-colors">
                🗑️ Remove
              </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input type="text"
                       name="subscriptions[0][name]"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                       placeholder="Netflix"
                       required>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Amount</label>
                <input type="number"
                       name="subscriptions[0][amount]"
                       step="0.01"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                       placeholder="19.99"
                       required>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Billing Cycle</label>
                <select name="subscriptions[0][billing_cycle]"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                        required>
                  <option value="">Select...</option>
                  <option value="weekly">Weekly</option>
                  <option value="monthly">Monthly</option>
                  <option value="yearly">Yearly</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Next Billing Date</label>
                <input type="date"
                       name="subscriptions[0][date_recurrence]"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                       required>
              </div>

              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                <select name="subscriptions[0][category_id]"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                        required>
                  <option value="">Select...</option>
                  <% Category.all.each do |category| %>
                    <option value="<%= category.id %>"><%= category.name %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </div>

        </div>

        <div class="mt-6 space-y-3">
          <button type="button"
                  data-action="bulk-subscriptions#addRow"
                  class="w-full bg-green-500 hover:bg-green-600 text-white font-semibold px-4 py-3 rounded-lg transition-colors">
            ➕ Add Another Subscription
          </button>

          <%= f.submit "Create All Subscriptions",
              class: "w-full bg-[#1B2B4B] hover:bg-[#85B7EB] text-white font-semibold px-4 py-3 rounded-lg transition-colors" %>
        </div>

      <% end %>

      <!-- Template for new rows -->
      <template data-bulk-subscriptions-target="template">
        <div data-bulk-subscription-row class="border border-gray-200 rounded-lg p-5 bg-gray-50">
          <div class="flex justify-between items-center mb-4">
            <h4 class="font-semibold text-gray-700 text-lg">Subscription #NEW</h4>
            <button type="button"
                    data-action="bulk-subscriptions#removeRow"
                    class="text-red-500 hover:text-red-700 font-medium text-sm transition-colors">
              🗑️ Remove
            </button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input type="text"
                     name="subscriptions[INDEX][name]"
                     class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                     placeholder="Netflix"
                     required>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Amount</label>
              <input type="number"
                     name="subscriptions[INDEX][amount]"
                     step="0.01"
                     class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                     placeholder="19.99"
                     required>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Billing Cycle</label>
              <select name="subscriptions[INDEX][billing_cycle]"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                      required>
                <option value="">Select...</option>
                <option value="weekly">Weekly</option>
                <option value="monthly">Monthly</option>
                <option value="yearly">Yearly</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Next Billing Date</label>
              <input type="date"
                     name="subscriptions[INDEX][date_recurrence]"
                     class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                     required>
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
              <select name="subscriptions[INDEX][category_id]"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                      required>
                <option value="">Select...</option>
                <% Category.all.each do |category| %>
                  <option value="<%= category.id %>"><%= category.name %></option>
                <% end %>
              </select>
            </div>
          </div>
        </div>
      </template>
    </div>

  </div>

  <!-- Right Column: Preview (Sticky) -->
  <div class="lg:sticky lg:top-4 lg:self-start">
    <div class="bg-white rounded-lg shadow-md p-6">
      <h3 class="text-2xl font-bold mb-4 text-gray-800">📊 Preview</h3>

      <%= turbo_frame_tag "preview" do %>
        <div class="text-gray-500 text-center p-12 border-2 border-dashed border-gray-300 rounded-lg bg-gray-50">
          <div class="text-4xl mb-3">👀</div>
          <p class="font-medium mb-2">Preview will appear here</p>
          <p class="text-sm">Upload a CSV to see your subscriptions</p>
        </div>
      <% end %>
    </div>
  </div>

</div>
