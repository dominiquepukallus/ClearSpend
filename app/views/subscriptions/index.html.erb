<div class="flex gap-6 px-10 pt-10">
  <div class="w-[45%] flex flex-col">
    <%= turbo_frame_tag "calendar", class: "flex flex-col" do %>
      <%= render "subscriptions/calendar", subscriptions: @calendar_subscriptions %>
    <% end %>
    <%= render "subscriptions/category_filter" %>
  </div>

  <div class="flex-1 pt-2.5 flex flex-col">
    <%= render "subscriptions/search", subscriptions: @subscriptions %>
  </div>
</div>
