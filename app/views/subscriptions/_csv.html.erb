<div class="flex items-center grid grid-cols gap-8">
  <div class="space-y-8">
    <div class="bg-white rounded-lg shadow-md p-6">
      <h3 class="text-2xl font-bold mb-4 text-gray-800">Upload CSV</h3>

      <%= form_with url: parse_csv_subscriptions_path,
          method: :post,
          multipart: true,
          data: { turbo_frame: "preview", controller: "file-upload", action:"submit->file-upload#startLoading" } do |f| %>

        <div data-controller="file-upload" class="border-2 border-dashed border-gray-300 rounded-lg p-8 mb-6 bg-gray-50 hover:bg-gray-100 transition-colors">
          <%= f.label :csv_file, class: "block mb-4 cursor-pointer" do %>
            <div class="flex justify-center align-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-12">
                <path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" />
              </svg>
            </div>
            <div class="text-gray-700 font-semibold text-center">Choose CSV File</div>
            <div class="text-sm text-gray-500 mt-2 text-center">AI will categorize your subscriptions</div>
            <div data-file-upload-target="filename" class="text-sm text-gray-500 mt-2 text-center hidden"></div>
          <% end %>

          <%= f.file_field :csv_file,
              accept: ".csv",
              data: { action: "change->file-upload#showFilename"},
              class: "hidden" %>
        </div>

        <%= f.submit "Upload and Parse",
            data: { file_upload_target: "submit", loading_text: "Parsing.." },
            class: "w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg cursor-pointer transition-colors" %>
      <% end %>
    </div>
    <div class="lg:sticky lg:top-4 lg:self-start">
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-2xl font-bold mb-4 text-gray-800">Preview</h3>

        <%= turbo_frame_tag "preview" do %>
          <div class="text-gray-500 text-center p-12 border-2 border-dashed border-gray-300 rounded-lg bg-gray-50">
            <div class="text-4xl mb-3"></div>
            <p class="font-medium mb-2">Preview will appear here</p>
            <p class="text-sm">Upload a CSV to see your subscriptions</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
