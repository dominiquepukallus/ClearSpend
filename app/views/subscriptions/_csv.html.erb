<div>
  <h3 class="text-xl font-bold mb-4">Upload CSV</h3>

  <%= form_with url: parse_csv_subscriptions_path,
      method: :post,
      multipart: true,
      data: { turbo_frame: "preview" } do |f| %>

    <div class="border-2 border-dashed rounded-lg p-8 mb-6 bg-gray-50">
      <%= f.label :csv_file, class: "block mb-4" do %>
        <div class="text-2xl mb-2 text-center">📄</div>
        <div class="text-gray-700 font-semibold text-center">Choose CSV File</div>
        <div class="text-sm text-gray-500 mt-2 text-center">AI will categorize your subscriptions</div>
      <% end %>

      <%= f.file_field :csv_file,
          accept: ".csv",
          class: "block w-full mt-4" %>
    </div>

    <%= f.submit "Upload and Parse",
        class: "bg-blue-500 hover:bg-blue-600 text-white px-6 py-2 rounded cursor-pointer" %>
  <% end %>

  <div class="mt-6">
    <%= turbo_frame_tag "preview" do %>
      <div class="text-gray-500 text-center p-8 border-2 border-dashed rounded">
        Preview will appear here after upload...
      </div>
    <% end %>
  </div>
</div>
