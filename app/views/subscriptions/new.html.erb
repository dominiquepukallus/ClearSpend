<div class="flex flex-col items-center justify-center mt-10">
  <div class="w-lg">
    <h1>New Subscription Upload</h1>

    <%= turbo_frame_tag "upload_form" do %>
      <%= link_to "Manual Entry", new_subscription_path(mode: "manual_upload"),
        data: { turbo_frame: "upload_form" } %>
      <%= link_to "CSV Upload", new_subscription_path(mode: "csv"),
        data: { turbo_frame: "upload_form" } %>
      <%= link_to "Bulk Entry", new_subscription_path(mode: "bulk_upload"),
        data: { turbo_frame: "upload_form"} %>
    <%= render partial: @mode || :manual_upload  %>
    <% end %>
  </div>
</div>
