<div class="bg-[#f4f5f7]" style="min-height: calc(100vh - 60px);">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="text-center mb-10">
      <h1 class="text-[#1B2B4B] font-semibold mb-2" style="font-family: 'Londrina Solid', sans-serif; font-size: 2rem;">
        Add Subscriptions
      </h1>
      <p class="text-gray-600">Choose how you'd like to add your subscriptions</p>
    </div>

    <%= turbo_frame_tag "upload_flow" do %>
      <% if @mode.nil? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">

          <%= link_to new_subscription_path(mode: "manual_upload"),
              data: { turbo_frame: "upload_flow" },
              class: "group block p-8 bg-white rounded-lg shadow-[4px_2px_16px_#B5D4F4] outline outline-1 outline-gray-300 hover:outline-[#85B7EB] transition-all cursor-pointer" do %>
            <div class="text-center">
              <div class="flex justify-center items-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-[#1B2B4B]">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                </svg>
              </div>
              <h3 class="text-xl text-gray-900 font-semibold mb-2">Manual Entry</h3>
              <p class="text-gray-600 text-sm mb-4">Manually add one or more subscriptions at a time</p>
              <div class="text-[#1B2B4B] font-medium group-hover:text-[#85B7EB] transition-colors">Get started →</div>
            </div>
          <% end %>

          <%= link_to new_subscription_path(mode: "csv"),
              data: { turbo_frame: "upload_flow" },
              class: "group block p-8 bg-white rounded-lg shadow-[4px_2px_16px_#B5D4F4] outline outline-1 outline-gray-300 hover:outline-[#85B7EB] transition-all cursor-pointer" do %>
            <div class="text-center">
              <div class="flex justify-center items-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-[#1B2B4B]">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" />
                </svg>
              </div>
              <h3 class="text-xl text-gray-900 font-semibold mb-2">Upload CSV</h3>
              <p class="text-gray-600 text-sm mb-4">Import from your bank statement or existing budget spreadsheets</p>
              <div class="text-[#1B2B4B] font-medium group-hover:text-[#85B7EB] transition-colors">Get started →</div>
            </div>
          <% end %>
        </div>

      <% else %>

        <div class="max-w-4xl mx-auto">
          <%= link_to new_subscription_path,
              data: { turbo_frame: "upload_flow" },
              class: "inline-flex items-center gap-2 text-gray-600 hover:text-[#1B2B4B] mb-6 font-medium transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to options
          <% end %>

          <%= render partial: @mode %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
