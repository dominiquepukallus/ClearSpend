<div data-controller="search" class="flex flex-col h-full">

  <!-- Active / Cancelled filter -->
  <div class="flex mx-6 mb-4 gap-6">
    <%= link_to subscriptions_path(query: params[:query], sort: params[:sort], category_ids: params[:category_ids]),
        class: "flex items-center gap-2 pb-2 text-sm font-medium transition-colors #{params[:status_filter] != 'cancelled' ? 'text-[#1B2B4B] border-b-2 border-[#1B2B4B]' : 'text-gray-400 hover:text-gray-600'}" do %>
      <span class="inline-block size-2.5 rounded-full bg-[#22C55E]"></span>
      Active
    <% end %>

    <%= link_to subscriptions_path(query: params[:query], sort: params[:sort], status_filter: 'cancelled', category_ids: params[:category_ids]),
        class: "flex items-center gap-2 pb-2 text-sm font-medium transition-colors #{params[:status_filter] == 'cancelled' ? 'text-[#1B2B4B] border-b-2 border-[#1B2B4B]' : 'text-gray-400 hover:text-gray-600'}" do %>
      <span class="inline-block size-2.5 rounded-full bg-[#E24B4A]"></span>
      Cancelled
    <% end %>
  </div>

  <!-- Search and filter -->
  <div class="flex mb-4 px-6 gap-3 w-full">
    <%= form_with url: subscriptions_path, method: :get, data: { turbo_frame: "_top" }, class: "flex-1" do |f| %>
      <div class="relative w-full shadow-[4px_2px_16px_#B5D4F4]">

        <!-- Search icon -->
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
          <svg class="size-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
          </svg>
        </div>

        <!-- Search bar -->
        <%= f.search_field :query,
              value: params[:query],
              placeholder: "Search subscriptions...",
              data: { search_target: "input", action: "input->search#filter" },
              class: "block w-full rounded-md border-0 bg-white py-3 pl-10 pr-3 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 placeholder:text-gray-500 focus:outline-2 focus:outline-[#1B2B4B] dark:bg-white/10 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>

        <% if params[:query].present? %>
          <%= link_to subscriptions_path, data: { turbo_frame: "_top" }, class: "absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" do %>
            <svg class="size-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
            </svg>
          <% end %>
        <% end %>
      </div>
    <% end %>


      <!-- SORT BY -->
      <div class="relative" data-controller="custom-select">
        <%= form_with url: subscriptions_path, method: :get, data: { turbo_frame: "_top" } do |f| %>
          <%= f.hidden_field :query, value: params[:query] %>
          <%= f.hidden_field :upcoming_week, value: params[:upcoming_week] %>
          <input type="hidden" name="sort" data-custom-select-target="input" value="<%= params[:sort] %>">

          <% sort_labels = { "a_to_z" => "A → Z", "most_expensive" => "Most expensive $$$", "least_expensive" => "Least expensive $", "categories" => "Categories" } %>

          <button type="button"
              data-custom-select-target="button"
              data-action="click->custom-select#toggle"
              class="flex items-center gap-2 rounded-md bg-[#1B2B4B] text-white px-4 py-3 text-sm font-medium outline outline-1 outline-gray-400 whitespace-nowrap w-fit">
            <span data-custom-select-target="label"><%= sort_labels[params[:sort]] || "Sort by" %></span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>

          <div data-custom-select-target="menu" class="hidden absolute top-full left-0 mt-1 bg-white rounded-md shadow-lg outline outline-1 outline-gray-200 z-50 min-w-full">
            <% [["Sort by", ""], ["A → Z", "a_to_z"], ["Most expensive $$$", "most_expensive"], ["Least expensive $", "least_expensive"], ["Categories", "categories"]].each do |label, value| %>
              <button type="button"
                  data-action="click->custom-select#select"
                  data-value="<%= value %>"
                  data-label="<%= label %>"
                  class="block w-full text-left my-2 px-4 text-sm text-gray-700 hover:bg-gray-50 whitespace-nowrap <%= params[:sort] == value ? 'font-semibold text-[#1B2B4B]' : '' %>">
                <%= label %>
              </button>
            <% end %>
          </div>
        <% end %>
      </div>


      <!-- UPCOMING -->
      <% unless params[:status_filter] == 'cancelled' %>
        <div class="relative">
          <%= link_to subscriptions_path(query: params[:query], category_ids: params[:category_ids], upcoming_week: true, sort: params[:sort], status_filter: params[:status_filter], month: params[:month]),
            class: "flex items-center gap-2 rounded-md px-4 py-3 text-sm font-semibold outline outline-1 outline-[#F9E9E9] #{params[:upcoming_week].present? ? 'bg-[#E24B4A] text-white' : 'bg-[#F8C8C8] text-gray-900'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
            Upcoming
          <% end %>

          <% if params[:upcoming_week].present? %>
            <%= link_to subscriptions_path(query: params[:query], category_ids: params[:category_ids], sort: params[:sort], status_filter: params[:status_filter], month: params[:month]),
                class: "absolute -top-2 -right-2 flex items-center justify-center size-4 rounded-full bg-[#F9E9E9] text-gray-900 hover:bg-red-600 hover:text-white" do %>
              <svg class="size-3" viewBox="0 0 20 20" fill="currentColor">
                <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
              </svg>
            <% end %>
          <% end %>
        </div>
      <% end %>

    </div>

    <!-- SUBSCRIPTIONS LISTS -->
    <!-- WHEN SORTED BY CATEGORIES -->
    <% if params[:sort] == "categories" %>
      <div class="mx-6 rounded-md shadow-[4px_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 overflow-y-scroll" style="max-height: 650px">
        <% @grouped_subscriptions.each do |category, subs| %>
          <div class="mb-3 rounded-md overflow-hidden">
            <div class="px-4 py-2" style="background-color: <%= category.hex_color %>25;">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: <%= category.hex_color %>;"><%= category.name %></span>
            </div>
            <% subs.each_with_index do |sub, index| %>
              <%= link_to subscription_path(sub), data: { turbo_frame: "_top" },
                  class: "flex items-center justify-between px-4 py-3 text-sm text-gray-900 hover:bg-gray-50 block #{index < subs.size - 1 ? 'border-b border-gray-100' : ''}" do %>
                <span class="font-medium"><%= sub.name %></span>
                <span class="text-gray-500">$<%= sub.amount.to_i %> <span class="text-xs"><%= sub.billing_cycle %></span></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>

    <!-- ANY OTHER SORTING  -->
    <% else %>
      <div class="mx-6 rounded-md bg-white shadow-[4px_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 overflow-y-scroll" style="max-height: 650px">
        <% subscriptions.each do |sub| %>
          <%= link_to subscription_path(sub), data: { turbo_frame: "_top", search_target: "item", name: sub.name },
              class: "flex items-center justify-between px-4 py-3 text-sm text-gray-900 hover:bg-gray-50 border-b border-gray-100 last:border-0" do %>
            <div class="flex items-center gap-3">
              <% if (logo = subscription_logo_url(sub)) %>
                <img src="<%= logo %>" alt="<%= sub.name %>" class="size-10 rounded border border-gray-200 object-contain">
              <% else %>
                <div class="rounded border border-gray-200 size-10"></div>
              <% end %>
              <div>
                <span class="font-medium"><%= sub.name %></span>
                <% next_date = sub.next_billing_date %>
                <% if next_date %>
                  <div class="text-xs text-gray-500"><%= next_date.strftime("%d %B %Y") %></div>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-3 text-gray-500">
              <span>
                <% if sub.shared? %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                  </svg>
                <% end %>
              </span>
              <div class="flex items-baseline gap-1">
                <span>$<%= sub.amount.to_i %></span>
                <span class="text-xs"><%= sub.billing_cycle %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
</div>
