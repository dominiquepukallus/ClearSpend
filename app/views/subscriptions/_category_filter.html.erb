<div id="category_filter" class="mt-3 shrink-0 shadow-[4px_2px_16px_#B5D4F4] outline outline-1 outline-gray-400 rounded-md flex flex-col">
  <div class="flex items-center justify-between bg-[#85B7EB]">
    <%= link_to categories_path,
        data: { turbo_frame: "drawer_content" },
        class: "flex-1 flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-white hover:bg-[#1B2B4B] transition-colors" do %>
      All categories
    <% end %>

    <% if params[:category_ids].present? %>
      <%= link_to subscriptions_path(month: params[:month], query: params[:query], sort: params[:sort], upcoming_week: params[:upcoming_week], status_filter: params[:status_filter]),
          class: "px-3 py-1.5 text-white hover:text-gray-200" do %>
        <svg class="size-4" viewBox="0 0 20 20" fill="currentColor">
          <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
        </svg>
      <% end %>
    <% end %>
  </div>

  <% selected_ids = params[:category_ids].to_s.split(",") %>
  <% seeded_names = ["Entertainment", "Well-being", "News & Information", "Food & Delivery / Meal kits", "Software & Productivity", "Shopping & Retail"] %>
  <% default_categories = Category.where(name: seeded_names) %>
  <% custom_categories = Category.where.not(name: seeded_names) %>

  <!-- Default categories dropdown IF CUSTOMIZED-->
  <% if custom_categories.any? %>
    <details class="group" open>
      <summary class="flex items-center justify-between px-4 py-1.5 text-xs font-medium text-gray-500 cursor-pointer hover:bg-gray-50 list-none">
        Default
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-3 transition-transform group-open:rotate-180">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </summary>
      <div class="grid grid-cols-3 pb-1">
        <% default_categories.each do |category| %>
          <% new_ids = selected_ids.include?(category.id.to_s) ? selected_ids - [category.id.to_s] : selected_ids + [category.id.to_s] %>
          <%= link_to subscriptions_path(month: params[:month], query: params[:query], sort: params[:sort], upcoming_week: params[:upcoming_week], status_filter: params[:status_filter], category_ids: new_ids.join(",")),
              class: "flex items-center gap-1 px-6 py-1 text-xs font-normal transition-colors #{selected_ids.include?(category.id.to_s) ? 'text-white rounded-md mx-0.5 my-0.5' : 'text-gray-600 hover:bg-gray-100'}",
              style: selected_ids.include?(category.id.to_s) ? "background-color: #{category.hex_color}90;" : "" do %>
            <span class="inline-block size-1.5 rounded-full flex-shrink-0" style="background-color: <%= category.hex_color %>;"></span>
            <%= category.name.truncate(35) %>
          <% end %>
        <% end %>
      </div>
    </details>

    <!-- Custom categories dropdown (only if any exist) -->
      <details class="group" open>
        <summary class="flex items-center justify-between px-4 py-1.5 text-xs font-medium text-gray-500 cursor-pointer hover:bg-gray-50 list-none border-t border-gray-100">
          Your categories
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-3 transition-transform group-open:rotate-180">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <div class="grid grid-cols-3 pb-1">
          <% custom_categories.each do |category| %>
            <% new_ids = selected_ids.include?(category.id.to_s) ? selected_ids - [category.id.to_s] : selected_ids + [category.id.to_s] %>
            <%= link_to subscriptions_path(month: params[:month], query: params[:query], sort: params[:sort], upcoming_week: params[:upcoming_week], status_filter: params[:status_filter], category_ids: new_ids.join(",")),
                class: "flex items-center gap-1 px-6 py-1 text-xs font-normal transition-colors #{selected_ids.include?(category.id.to_s) ? 'text-white rounded-md mx-0.5 my-0.5' : 'text-gray-600 hover:bg-gray-100'}",
                style: selected_ids.include?(category.id.to_s) ? "background-color: #{category.hex_color}90;" : "" do %>
              <span class="inline-block size-1.5 rounded-full flex-shrink-0" style="background-color: <%= category.hex_color %>;"></span>
              <%= category.name.truncate(12) %>
            <% end %>
          <% end %>
        </div>
      </details>

    <% else %>
      <div class="grid grid-cols-2 mt-2">
        <% default_categories.each do |category| %>
          <% new_ids = selected_ids.include?(category.id.to_s) ? selected_ids - [category.id.to_s] : selected_ids + [category.id.to_s] %>
          <%= link_to subscriptions_path(month: params[:month], query: params[:query], sort: params[:sort], upcoming_week: params[:upcoming_week], status_filter: params[:status_filter], category_ids: new_ids.join(",")),
              class: "flex items-center gap-2 px-6 py-1.5 text-sm font-normal transition-colors #{selected_ids.include?(category.id.to_s) ? 'text-white rounded-md mx-1 my-0.5' : 'text-gray-600 hover:bg-gray-100'}",
              style: selected_ids.include?(category.id.to_s) ? "background-color: #{category.hex_color}90;" : "" do %>
            <span class="inline-block size-2 rounded-full" style="background-color: <%= category.hex_color %>;"></span>
            <%= category.name %>
          <% end %>
        <% end %>
      </div>
  <% end %>

  <!-- ADD A CATEGORY BUTTON -->
  <div class="flex items-center justify-end mb-1 border-gray-100">
    <%= link_to new_category_path,
        data: { turbo_frame: "drawer_content", action: "click->drawer#open" },
        class: "flex items-center gap-1 px-5 py-1.5 text-sm text-gray-500 hover:text-[#1B2B4B] transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Add
    <% end %>
  </div>
</div>
