<nav class="bg-[#1B2B4B] px-8 py-2 flex items-center fixed top-0 left-0 right-0 z-50 shadow-md">
  <!-- Logo -->
  <div class="flex-1">
    <%= link_to authenticated_root_path do %>
      <%= image_tag "logo_dark.svg", class: "h-8" %>
    <% end %>
  </div>

  <!-- Nav links -->
  <% if user_signed_in? %>
    <div class="flex items-center gap-6">
      <%# <%= link_to "Home", "", class: "text-white hover:text-[#85B7EB] transition-colors no-underline" %>
      <%= link_to "Subscriptions", subscriptions_path, class: "text-white hover:text-[#85B7EB] transition-colors no-underline" %>
      <%= link_to "Insights", insights_path, class: "text-white hover:text-[#85B7EB] transition-colors no-underline" %>
      <%= link_to "Add Subscription", new_subscription_path, class: "text-white hover:text-[#85B7EB] transition-colors no-underline" %>
    </div>

    <div class="flex-1 flex items-center justify-end gap-2">
      <!-- New Chat Button -->
      <%= button_to chats_path, method: :post, class: "inline-flex items-center gap-1.5 rounded-md bg-[#b5d4f4] px-3 py-2 text-sm font-semibold text-[#1B2B4B] hover:bg-white transition-colors" do %>
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
          <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
        </svg>
        New Chat
      <% end %>

      <div class="w-px h-8 bg-white/20 mx-2"></div>

      <div class="relative">
        <details class="notifications-dropdown">
          <summary class="list-none cursor-pointer">
            <div class="relative w-10 h-10 rounded-full flex items-center justify-center hover:bg-white/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
              </svg>
              <% unread_count = unread_count = current_user.notifications.unread.count %>
              <% if unread_count > 0 %>
                <span class="absolute -top-1 -right-1 inline-flex items-center justify-center min-w-[20px] h-5 px-1 text-xs font-bold text-white bg-red-500 rounded-full">
                  <%= unread_count %>
                </span>
              <% end %>
            </div>
          </summary>
          <%= render "shared/notifications" %>
        </details>
      </div>

      <el-dropdown class="inline-block">
        <button class="w-10 h-10 rounded-full bg-[#b5d4f4] flex items-center justify-center text-[#1B2B4B] text-sm font-semibold hover:bg-white transition-colors">
          <%= current_user.initials %>
        </button>
        <el-menu anchor="bottom end" popover class="w-56 origin-top-right divide-y divide-gray-100 rounded-md bg-white shadow-lg ring-1 ring-black/5 transition [--anchor-gap:theme(spacing.2)] data-closed:scale-95 data-closed:opacity-0 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
          <div class="px-4 py-3">
            <p class="text-sm text-gray-500">Signed in as</p>
            <p class="truncate text-sm font-medium text-gray-900"><%= current_user.email %></p>
          </div>
          <div class="py-1">
            <%= link_to "Account Settings", edit_user_registration_path(current_user), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors no-underline" %>
            <%= link_to "Add New Subscription", new_subscription_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors no-underline" %>
          </div>
          <div class="py-1">
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "block w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-100 transition-colors" %>
          </div>
        </el-menu>
      </el-dropdown>
    </div>
  <% else %>
    <div class="flex-1 flex justify-end">
      <%= link_to "Login", new_user_session_path, class: "text-white hover:text-[#85B7EB] transition-colors no-underline" %>
    </div>
  <% end %>
</nav>
