<nav class="bg-[#1B2B4B] px-8 py-2 flex items-center justify-between fixed top-0 left-0 right-0 z-50">
  <!-- Logo -->
  <%= link_to root_path do %>
    <%= image_tag "logo_dark.svg", class: "h-8" %>
  <% end %>

  <!-- Nav links -->
  <% if user_signed_in? %>
    <div class="flex items-center gap-6">
      <%= link_to "Home", root_path, class: "text-white hover:text-[#85B7EB]", style: "text-decoration: none;" %>
      <%= link_to "Subscriptions", subscriptions_path, class: "text-white hover:text-[#85B7EB]", style: "text-decoration: none;" %>
      <%= link_to "Dashboard", dashboard_path, class: "text-white hover:text-[#85B7EB]", style: "text-decoration: none;" %>
    </div>

    <!-- User dropdown -->
    <div class="flex items-center gap-4">
      <%= link_to "CHAT", chats_path, class: "font-medium hover:text-gray-600", style: "font-family: 'Londrina Solid', sans-serif; letter-spacing: 0.02em; font-size: 1.2rem;" %>
        <div class="relative">
          <details class="notifications-dropdown">
            <summary class="notification-bell-button list-none cursor-pointer">
              <div class="relative w-10 h-10 rounded-full flex items-center justify-center border border-transparent hover:border-[#b5d4f4] transition-colors cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" class="size-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                </svg>
                <% unread_count = current_user.notifications.where(type: 'SharedSubscription::Notification').unread.count %>
                <% if unread_count > 0 %>
                  <span class="absolute top-0 right-0 inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-red-600 rounded-full border-2 border-white">
                    <%= unread_count %>
                  </span>
                <% end %>
              </div>
            </summary>
            <%= render "shared/notifications" %>
          </details>
        </div>
      <el-dropdown class="inline-block">
        <button class="inline-flex items-center justify-center">
          <div class="w-10 h-10 rounded-full bg-[#b5d4f4] flex items-center justify-center text-[#1B2B4B] text-sm font-semibold hover:bg-[#75B7EB] transition-colors">
            <%= current_user.initials %>
          </div>
        </button>
        <el-menu anchor="bottom end" popover class="w-56 origin-top-right divide-y divide-gray-100 rounded-md bg-white shadow-lg outline-1 outline-black/5 transition transition-discrete [--anchor-gap:--spacing(2)] data-closed:scale-95 data-closed:transform data-closed:opacity-0 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
          <div class="px-4 py-3">
            <p class="text-sm text-gray-700">Signed in as</p>
            <p class="truncate text-sm font-medium text-gray-900"><%= current_user.email %></p>
          </div>
          <div class="py-1">
            <%= link_to "Account Settings", edit_user_registration_path(current_user), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 focus:bg-gray-100 focus:text-gray-900 focus:outline-hidden" %>
          </div>
          <div class="py-1">
            <%= link_to "Add New Subscriptions", new_subscription_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 focus:bg-gray-100 focus:text-gray-900 focus:outline-hidden" %>
          <div class="py-1">
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "block w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-100 focus:bg-gray-100 focus:text-gray-900 focus:outline-hidden" %>
          </div>
        </el-menu>
      </el-dropdown>
    </div>
  <% else %>
    <%= link_to "Login", new_user_session_path, class: "text-white hover:text-[#85B7EB]", style: "text-decoration: none;" %>
  <% end %>
</nav>
