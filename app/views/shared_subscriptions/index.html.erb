<div class="max-w-6xl mx-auto px-5 py-10">
  <div class="mb-6">
    <h2 class="text-2xl font-bold mb-4">Shared Subscriptions</h2>
    <p class="text-gray-600">Manage subscriptions shared with you and by you</p>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="bg-white border border-gray-300 rounded-lg p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold">Shared with you</h2>
        <% pending_count = @received_shares.where(status: 'pending').count %>
        <% if pending_count > 0 %>
          <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-sm font-semibold rounded-full">
            <%= pending_count %> pending
          </span>
        <% end %>
      </div>

      <% if @received_shares.any? %>
        <div class="space-y-3">
          <% @received_shares.each do |shared| %>
            <div class="border border-gray-300 rounded-lg p-4 <%= 'bg-yellow-50 border-yellow-300' if shared.status == 'pending' %>">
              <div class="flex justify-between items-start mb-3">
                <div>
                  <h3 class="font-semibold"><%= shared.subscription.name %></h3>
                  <p class="text-sm text-gray-600">
                    $<%= shared.subscription.amount.to_i %> / <%= shared.subscription.billing_cycle %>
                  </p>
                </div>
                <span class="px-2 py-1 rounded-full text-xs font-semibold <%= shared.status == 'accepted' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
                  <%= shared.status.capitalize %>
                </span>
              </div>

              <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
                <div class="w-6 h-6 rounded-full bg-gray-300 flex items-center justify-center text-xs font-semibold">
                  <%= shared.subscription.user.first_name.first.upcase %><%= shared.subscription.user.last_name.first.upcase %>
                </div>
                <span><%= shared.subscription.user.email %></span>
              </div>

              <div class="flex items-center justify-between pt-3 border-t border-gray-200">
                <p class="text-sm font-medium">Your share: <%= shared.share_percentage.to_i %>%</p>

                <% if shared.status == 'pending' %>
                  <div class="flex gap-2">
                    <%= button_to "Accept", accept_shared_subscription_path(shared),
                        method: :patch,
                        class: "px-3 py-1 bg-green-600 text-white text-sm font-semibold rounded hover:bg-green-700" %>
                    <%= button_to "Reject", reject_shared_subscription_path(shared),
                        method: :patch,
                        data: { turbo_confirm: "Are you sure?" },
                        class: "px-3 py-1 bg-red-600 text-white text-sm font-semibold rounded hover:bg-red-700" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <p class="text-gray-600">No subscriptions shared with you yet</p>
        </div>
      <% end %>
    </div>

    <div class="bg-white border border-gray-300 rounded-lg p-6">
      <h2 class="text-xl font-bold mb-4">Currently Sharing</h2>

      <% if @sent_shares.any? %>
        <div class="space-y-3">
          <% @sent_shares.each do |sub| %>
            <div class="border border-gray-300 rounded-lg p-4">
              <div class="mb-3">
                <h3 class="font-semibold"><%= sub.name %></h3>
                <p class="text-sm text-gray-600">
                  $<%= sub.amount.to_i %> / <%= sub.billing_cycle %>
                </p>
              </div>

              <div class="pt-3 border-t border-gray-200">
                <p class="text-sm font-semibold mb-2">Shared with:</p>
                <div class="space-y-2">
                  <% sub.shared_subscriptions.each do |shared| %>
                    <div class="flex justify-between items-center">
                      <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-gray-300 flex items-center justify-center text-xs font-semibold">
                          <%= shared.user.first_name.first.upcase %><%= shared.user.last_name.first.upcase %>
                        </div>
                        <div>
                          <p class="text-sm font-medium"><%= shared.user.email %></p>
                          <p class="text-xs text-gray-600"><%= shared.share_percentage.to_i %>% share</p>
                        </div>
                      </div>
                      <span class="px-2 py-1 rounded-full text-xs font-semibold <%= shared.status == 'accepted' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
                        <%= shared.status.capitalize %>
                      </span>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-12">
          <p class="text-gray-600 mb-4">You haven't shared any subscriptions yet</p>
          <%= link_to "Add Subscription", new_subscription_path, class: "text-blue-600 font-semibold hover:underline" %>
        </div>
      <% end %>
    </div>
  </div>
  <div class="mt-6">
    <%= link_to "← Back to Profile", user_path(current_user), class: "text-gray-600 hover:text-gray-900" %>
  </div>
</div>
