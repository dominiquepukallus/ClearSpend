<%= turbo_frame_tag "drawer_content" do %>
  <div class="flex flex-col h-full pt-4">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold text-[#1B2B4B]">Categories</h1>
      <button onclick="document.querySelector('[data-drawer-target=panel]').classList.add('translate-x-full'); document.querySelector('[data-drawer-target=overlay]').classList.add('hidden'); document.body.classList.remove('overflow-hidden')" class="text-gray-400 hover:text-[#1B2B4B] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <% seeded_names = ["Entertainment", "Well-being", "News & Information", "Food & Delivery / Meal kits", "Software & Productivity", "Shopping & Retail", "Customized"] %>
    <% seeded_categories = @categories.select { |c| seeded_names.include?(c.name) } %>
    <% custom_categories = @categories.reject { |c| seeded_names.include?(c.name) } %>

    <div class="flex flex-col gap-3">

      <!-- Default categories -->
      <div class="flex flex-col gap-3">
        <% seeded_categories.each do |category| %>
          <details class="group rounded-xl outline outline-1 outline-gray-200 overflow-hidden">
            <summary class="flex items-center gap-3 bg-white px-4 py-3 cursor-pointer list-none">
              <div class="flex items-center justify-center size-8 rounded-lg flex-shrink-0 <%= category.color %>">
                <!-- icon -->
              </div>
              <div class="min-w-0 flex-1">
                <p class="font-semibold text-[#1B2B4B] text-sm"><%= category.name %></p>
                <p class="text-xs text-gray-400"><%= category.subscriptions.where(user: current_user).count %> subscriptions</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="border-t border-gray-100">
              <% category.subscriptions.where(user: current_user).each do |sub| %>
                <%= link_to subscription_path(sub), data: { turbo_frame: "_top" },
                    class: "flex items-center justify-between px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 border-b border-gray-100 last:border-0" do %>
                  <span><%= sub.name %></span>
                  <span class="text-xs text-gray-400">$<%= sub.amount.to_i %> <%= sub.billing_cycle %></span>
                <% end %>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>

      <!-- Custom categories with bulk delete -->
      <% if custom_categories.any? %>
        <div class="border-t border-gray-100 pt-3">
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wide px-1 mb-2">Your categories</p>
          <%= form_with url: bulk_destroy_categories_path, method: :delete do |f| %>
            <div class="flex flex-col gap-2">
              <% custom_categories.each do |category| %>
                <div id="category_<%= category.id %>" class="relative flex items-center gap-3 rounded-xl bg-white outline outline-1 outline-gray-200 px-4 py-3 hover:shadow-[0_4px_20px_#85B7EB] transition-shadow">
                  <%= check_box_tag "category_ids[]", category.id, false,
                      class: "size-4 rounded border-gray-300 text-[#1B2B4B] focus:ring-[#1B2B4B] bulk-delete-checkbox" %>
                  <div class="flex items-center gap-3 flex-1 min-w-0">
                    <div class="flex items-center justify-center size-8 rounded-lg flex-shrink-0" style="background-color: <%= category.hex_color %>; color: white;">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      </svg>
                    </div>
                    <div class="min-w-0">
                      <p class="font-semibold text-[#1B2B4B] text-sm"><%= category.name %></p>
                      <p class="text-xs text-gray-400"><%= category.subscriptions.where(user: current_user).count %> subscriptions</p>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>

            <button type="submit" id="bulk-delete-btn"
                data-confirm="Delete selected categories?"
                class="hidden mt-3 w-full rounded-md bg-[#E24B4A] text-white px-4 py-2 text-sm font-medium hover:bg-red-600 transition-colors">
              Delete selected
            </button>
          <% end %>
        </div>
      <% end %>

      <!-- Add category -->
      <%= link_to new_category_path, data: { turbo_frame: "drawer_content" }, class: "flex items-center gap-3 rounded-xl bg-[#4ADE80]/30 px-4 py-3 hover:bg-[#4ADE80]/50 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        <p class="font-semibold text-gray-600 text-sm">Add a new category</p>
      <% end %>
    </div>
  </div>

  <script>
    document.querySelectorAll('.bulk-delete-checkbox').forEach(cb => {
      cb.addEventListener('change', () => {
        const checked = document.querySelectorAll('.bulk-delete-checkbox:checked').length
        document.getElementById('bulk-delete-btn').classList.toggle('hidden', checked === 0)
      })
    })
  </script>

  <script>
  document.querySelectorAll('details').forEach(detail => {
    detail.addEventListener('toggle', () => {
      if (detail.open) {
        document.querySelectorAll('details').forEach(other => {
          if (other !== detail) other.removeAttribute('open')
        })
      }
    })
  })
</script>
<% end %>
