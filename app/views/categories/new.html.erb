<%= turbo_frame_tag "drawer_content" do %>
  <div class="flex flex-col h-full pt-4">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold text-[#1B2B4B]">New category</h1>
      <button onclick="document.querySelector('[data-drawer-target=panel]').classList.add('translate-x-full'); document.querySelector('[data-drawer-target=overlay]').classList.add('hidden'); document.body.classList.remove('overflow-hidden')" class="text-gray-400 hover:text-[#1B2B4B] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Form -->
    <%= form_with model: @category, class: "flex flex-col gap-4", data: { turbo_frame: "_top" } do |f| %>
      <% if @category.errors.any? %>
        <div class="rounded-md bg-red-50 px-4 py-3 text-sm text-red-600">
          <% @category.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-[#1B2B4B] mb-1" %>
        <%= f.text_field :name, placeholder: "e.g. Transport", class: "w-full rounded-md border-0 bg-white py-3 px-4 text-sm text-gray-900 shadow-sm outline outline-1 outline-gray-400 focus:outline-2 focus:outline-[#1B2B4B]" %>
      </div>

      <div>
        <%= f.label :color, "Pick a color", class: "block text-sm font-medium text-[#1B2B4B] mb-2" %>
        <div class="flex flex-wrap gap-3">
          <%
            color_options = [
              { label: "Coral",   value: "bg-[#FF6B6B] text-white" },
              { label: "Indigo",  value: "bg-[#6366F1] text-white" },
              { label: "Amber",   value: "bg-[#F59E0B] text-white" },
              { label: "Emerald", value: "bg-[#10B981] text-white" },
              { label: "Rose",    value: "bg-[#F43F5E] text-white" },
              { label: "Sky",     value: "bg-[#0EA5E9] text-white" },
              { label: "Lime",    value: "bg-[#84CC16] text-white" },
              { label: "Cyan",    value: "bg-[#06B6D4] text-white" },
              { label: "Fuchsia", value: "bg-[#D946EF] text-white" },
              { label: "Navy",    value: "bg-[#1E3A5F] text-white" },
            ]
          %>
          <% color_options.each do |color| %>
            <label class="cursor-pointer">
              <%= f.radio_button :color, color[:value], class: "sr-only peer" %>
              <span class="flex items-center justify-center size-8 rounded-full peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-[#1B2B4B] transition-all <%= color[:value].split.first %>"
                    title="<%= color[:label] %>">
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit "Create", class: "cursor-pointer rounded-md bg-[#1B2B4B] px-5 py-3 text-sm font-medium text-white hover:bg-[#2a3f6e] transition-colors" %>
        <button type="button" onclick="document.querySelector('[data-drawer-target=panel]').classList.add('translate-x-full'); document.querySelector('[data-drawer-target=overlay]').classList.add('hidden'); document.body.classList.remove('overflow-hidden')" class="rounded-md px-5 py-3 text-sm font-medium text-gray-500 hover:text-[#1B2B4B] transition-colors">
          Cancel
        </button>
      </div>
    <% end %>
  </div>
<% end %>
