<div class="relative bg-[#f4f5f7]" style="min-height: calc(100vh - 60px);">
  <!-- Header -->
  <div class="px-6 py-6 mt-3">
    <div class="flex items-center justify-between max-w-3xl mx-auto">
      <h1 class="text-[#1B2B4B] font-semibold text-3xl">
        All Chats
      </h1>

      <%= button_to chats_path, method: :post, class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#1B2B4B] text-white font-semibold hover:bg-[#85B7EB] transition-colors text-sm" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Chat
      <% end %>
    </div>
  </div>

  <!-- Chat List -->
  <div class="px-6 py-4">
    <div class="max-w-3xl mx-auto space-y-3">
      <% if @chats.empty? %>
        <div class="text-center py-12">
          <p class="text-gray-500 mb-4">No chats yet. Start a conversation!</p>
          <%= button_to chats_path, method: :post, class: "inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[#1B2B4B] text-white font-semibold hover:bg-[#85B7EB] transition-colors" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Start New Chat
          <% end %>
        </div>
      <% else %>
        <% @chats.each do |chat| %>
          <div class="bg-white rounded-lg p-4 shadow-[4px_2px_16px_#B5D4F4] outline outline-1 outline-gray-300 hover:outline-[#85B7EB] transition-all group relative">
            <%= link_to chat_path(chat), class: "block" do %>
              <h5 class="text-gray-900 font-semibold text-base mb-1 pr-8"><%= chat.title %></h5>
              <p class="text-gray-500 text-sm"><%= chat.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            <% end %>

            <%= button_to chat_path(chat), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this chat?" }, class: "absolute top-4 right-4 text-gray-400 hover:text-red-600 transition-colors" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
