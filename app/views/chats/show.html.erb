<div class="relative bg-[#f4f5f7] pt-2" style="min-height: calc(100vh - 60px);">
  <!-- Header -->
  <div class="bg-white border-b border-gray-200 px-6 py-4 shadow-sm">
    <div class="flex items-center justify-between max-w-6xl mx-auto">
      <%= link_to chats_path, class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-[#1B2B4B] hover:text-[#85B7EB] transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        All Chats
      <% end %>

      <h1 class="text-center text-[#1B2B4B] font-semibold text-2xl">
        ClearSpend Assistant
      </h1>

      <%= link_to dashboard_path, class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-[#1B2B4B] hover:text-[#85B7EB] transition-colors" do %>
        Home
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      <% end %>
    </div>
  </div>

  <!-- Messages -->
  <div class="px-6 py-8 pb-40">
    <div class="max-w-3xl mx-auto space-y-8" id="messages">
      <% @chat.messages.order(:created_at).each do |message| %>
        <div class="flex <%= message.role == 'user' ? 'justify-end' : 'justify-start' %>">
          <div class="max-w-xl">
            <div class="rounded-lg px-4 py-3 <%= message.role == 'user' ? 'bg-[#1B2B4B] text-white' : 'bg-white text-gray-900 shadow-[4px_2px_16px_#B5D4F4] outline outline-1 outline-gray-300' %>">
              <% if message.role == 'assistant' %>
                <p style="white-space: pre-line;"><%= raw message.content.gsub(/\[([^\]]+)\]\(([^)]+)\)/, '<a href="\2" class="text-[#1B2B4B] hover:text-[#85B7EB] underline">\1</a>') %></p>
              <% else %>
                <p><%= message.content %></p>
              <% end %>
            </div>

            <% if message.role == "assistant" %>
              <% suggestions = message.metadata&.dig("suggestions") || [] %>
              <% if suggestions.any? %>
                <div class="mt-3 flex gap-3 overflow-x-auto pb-2">
                  <% suggestions.each do |suggestion| %>
                    <%= render "messages/suggestion", suggestion: suggestion, message: message %>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 px-6 py-4 shadow-lg z-10">
    <div class="max-w-3xl mx-auto">
      <%= form_with model: [@chat, @message], data: { turbo: false } do |f| %>
        <% if @message.errors.any? %>
          <p class="text-red-500 mb-2 text-sm"><%= @message.errors.full_messages.join(" | ") %></p>
        <% end %>

        <div class="flex gap-3 items-stretch">
          <%= f.text_area :content,
            placeholder: "Ask me about your subscriptions...",
            rows: 2,
            class: "flex-1 border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#85B7EB] focus:border-transparent resize-none" %>
          <%= f.submit "Send", class: "bg-[#1B2B4B] text-white px-6 rounded-lg hover:bg-[#85B7EB] transition cursor-pointer font-semibold items-stretch" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
