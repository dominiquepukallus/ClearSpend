<div class="flex flex-col items-center justify-center mt-10">
  <div class="w-full max-w-md px-4">
    <div class="flex flex-col items-center justify-center mb-8">
      <h2 class="text-2xl font-bold text-gray-900">Log in to ClearSpend</h2>
      <p class="text-gray-600 mt-3 text-center">Access your account, subscriptions, and spending insights</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= f.error_notification class: 'bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded mb-4' %>

      <div class="space-y-4">
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email" } %>

        <%= f.input :password,
                    required: true,
                    input_html: { autocomplete: "current-password" } %>
      </div>

      <div class="flex justify-between items-baseline-last mt-4 text-xs text-gray-600">
        <div>
          <% if devise_mapping.rememberable? %>
            <%= f.input :remember_me,
                        as: :boolean,
                        label: "Remember me",
                        wrapper_html: { class: 'mb-0' },
                        input_html: { class: 'mr-1' },
                        label_html: { class: 'inline-flex items-center cursor-pointer' } %>
          <% end %>
        </div>

        <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
          <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-[#1B2B4B] hover:underline hover:text-blue-600 dark:hover:text-blue-400" %>
        <% end %>
      </div>

      <%= f.button :submit, "Log in",
                   class: "w-full bg-[#1B2B4B] hover:bg-[#85B7EB] text-white px-4 py-2 rounded mt-6 transition-colors duration-200 font-medium" %>
    <% end %>

    <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
      <div class="text-center mt-6 text-sm text-gray-600">
        Don't have an account? <%= link_to "Sign up", new_registration_path(resource_name), class: "text-[#1B2B4B] hover:underline font-medium hover:text-blue-600 dark:hover:text-blue-400" %>
      </div>
    <% end %>
  </div>
</div>
