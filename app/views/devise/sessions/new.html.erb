<div class="flex flex-col items-center justify-center mt-10">
  <div class="w-lg">
    <div class="flex flex-col items-center justify-center">
      <h2>Log in to ClearSpend</h2>
      <p class="text-gray-600 mt-3">Access your account, subscriptions, and spending insights</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email" } %>
        <%= f.input :password,
                    required: true,
                    input_html: { autocomplete: "current-password" } %>
        <div class="flex justify-between text-xs text-gray-600">
          <div>
            <%= f.input :remember_me, as: :boolean, inline_label: "Remember me" if devise_mapping.rememberable? %>
          </div>
          <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <%= link_to "Forgot your password?", new_password_path(resource_name) %>
          <% end %>
        </div>

        <div class="flex justify-center bg-[#1B2B4B] hover:bg-[#85B7EB] rounded mt-2">
          <%= f.button :submit, "Log in", class: "text-white px-4 py-2 w-full" %>
        </div>
      </div>
    <% end %>

    <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
      <div class="text-center mt-6 text-sm text-gray-600">
        Don't have an account? <%= link_to "Sign up", new_registration_path(resource_name), class: "text-[#1B2B4B] hover:underline" %>
      </div>
    <% end %>
  </div>
</div>
