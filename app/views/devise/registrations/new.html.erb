<div class="flex flex-col items-center justify-center mt-10">
  <div class="w-full max-w-md px-4">
    <div class="flex flex-col items-center justify-center mb-8">
      <h2 class="text-2xl font-bold text-gray-900">Sign up to ClearSpend</h2>
      <p class="text-gray-600 mt-3 text-center">Get started and take control of your subscriptions</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification class: 'bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded mb-4' %>

      <div class="form-inputs">
        <%= f.input :first_name,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "given-name" } %>

        <%= f.input :last_name,
                    required: true,
                    input_html: { autocomplete: "family-name" } %>

        <%= f.input :alias,
                    required: true,
                    label: "User Alias",
                    hint: "5 characters minimum",
                    input_html: { autocomplete: "username" } %>

        <%= f.input :email,
                    required: true,
                    input_html: { autocomplete: "email" } %>

        <%= f.input :password,
                    required: true,
                    hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password" } %>

        <%= f.input :password_confirmation,
                    required: true,
                    label: "Confirm Password",
                    input_html: { autocomplete: "new-password" } %>
      </div>

      <%= f.button :submit, "Sign up",
                   class: "w-full bg-[#1B2B4B] hover:bg-[#85B7EB] text-white px-4 py-2 rounded mt-6 transition-colors duration-200 font-medium" %>
    <% end %>

    <%- if devise_mapping.authenticatable? && controller_name != 'sessions' %>
      <div class="text-center mt-6 text-sm text-gray-600">
        Have an account? <%= link_to "Log in", new_session_path(resource_name), class: "text-[#1B2B4B] hover:underline font-medium hover:text-blue-600 dark:hover:text-blue-400" %>
      </div>
    <% end %>
  </div>
</div>
